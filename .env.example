# ============================================
# LANDSCAPING CMS - Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# This file (.env.example) should be committed as documentation

# ============================================
# GitHub Configuration
# ============================================
# GitHub Personal Access Token
# Required scopes: repo (full control of private repositories)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository owner (username)
GITHUB_OWNER=your_github_username

# GitHub repository name
GITHUB_REPO=your_repository_name

# GitHub branch to use (default: main)
GITHUB_BRANCH=main

# ============================================
# Admin Security
# ============================================
# Admin dashboard password hash (bcrypt)
# Example: node -e "require('bcryptjs').hash('your_password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# Optional local-development fallback (ignored in production when hash is required)
# ADMIN_PASSWORD=local_dev_password_only

# Required in production: secret for signing admin session cookies
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace_with_random_hex_secret

# Optional admin session max age (seconds). Default: 28800 (8 hours)
# ADMIN_SESSION_MAX_AGE_SECONDS=28800

# Optional (production default false): allow outbound translation API calls
# ENABLE_EXTERNAL_TRANSLATION=true

# Optional (production default false): allow admin-provided custom CSS rendering
# ENABLE_ADMIN_CUSTOM_CSS=true

# ============================================
# API Configuration
# ============================================
# API base URL for client-side requests
# For development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public site URL used for canonical URLs, sitemap, robots, and social metadata
# Example: https://yourdomain.com
# If not set, app falls back to NEXT_PUBLIC_API_URL (or localhost in dev)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ============================================
# Optional Configuration
# ============================================
# Node environment
# - development: Reads/writes JSON files locally from disk (recommended for local development)
# - production: Uses GitHub API for all file operations
# Default: production
NODE_ENV=development

# Runtime content cache TTL in seconds for site rendering (production)
# Lower value = fresher content, higher value = fewer GitHub API calls
# Default used by app: 30
# CONTENT_CACHE_TTL_SECONDS=30

# Optional language routing fallback used by middleware (comma-separated)
# SITE_LANGUAGE_CODES=en,es,fr
# SITE_DEFAULT_LANGUAGE=en

# ============================================
# IMPORTANT: Localhost vs Deployed Site
# ============================================
# NODE_ENV=development:
#   - API reads/writes files directly from disk
#   - Works without GitHub credentials
#   - Good for local development and testing
#   - Changes are saved to src/data/content/*.json files
#
# NODE_ENV=production:
#   - API uses GitHub API for all file operations
#   - Requires valid GITHUB_TOKEN, GITHUB_OWNER, GITHUB_REPO
#   - Changes are committed to your GitHub repository
#   - Best for deployed sites with persistent storage
# EG
